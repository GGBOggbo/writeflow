# Database
# Main/testing now uses the shared postgres/Neon database.
# Put the real connection string in .env.local or your deployment environment,
# never commit it to git.
DATABASE_PROVIDER=postgres
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Optional local-only fallback:
# DATABASE_PROVIDER=sqlite
# DATABASE_URL=file:./data/dev.sqlite

# Better Auth 认证
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Optional separate HMAC secret for email verification codes. Falls back to BETTER_AUTH_SECRET.
AUTH_OTP_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Zeabur Email
# https://zeabur.com/docs/zh-CN/email/quick-start
ZEABUR_EMAIL_API_KEY=
ZEABUR_EMAIL_FROM="Writeflow <noreply@example.com>"

AI_PROVIDER=mock

OPENAI_API_KEY=
OPENAI_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5-pro
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Search is disabled by default. Set SEARCH_PROVIDER=bocha, jizhila, or wxrank to enable a provider.
SEARCH_PROVIDER=disabled
BOCHA_API_KEY=
WXRANK_API_KEY=
WXRANK_BASE_URL=https://data.wxrank.com
WXRANK_HISTORY_MIN_RESULTS=5
WXRANK_RESULT_LIMIT=8
WXRANK_DEEP_DIVE_LIMIT=8
WXRANK_COMMENT_TOP_N=10
JIZHILA_API_KEY=
JIZHILA_VERIFY_CODE=
# Optional: enrich top search results with read/like/share/comment metrics.
# Each enriched article calls read_zan_pro and may incur extra cost.
JIZHILA_ENRICH_READ_ZAN=false
JIZHILA_ENRICH_LIMIT=5
# Optional: after read_zan_pro, deep-dive selected core benchmark articles.
# article_html is about 0.04/article; article_comment2 is about 0.06/article.
JIZHILA_ENRICH_ARTICLE_HTML=false
JIZHILA_ENRICH_ARTICLE_LIMIT=2
JIZHILA_ENRICH_COMMENTS=false
JIZHILA_ENRICH_COMMENT_LIMIT=2
JIZHILA_ENRICH_COMMENT_TOP_N=10
